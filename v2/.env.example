# Supabase (create project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth - for Drive, Docs, Gmail (use same credentials as existing app or create new)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Cron secret - set a random string; cron-job.org will send this in header for security
CRON_SECRET=your-random-secret-string

# Optional: VPR migration - existing Google Sheet ID (read-only for migration)
VPR_MIGRATION_SHEET_ID=
